# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/behalfid

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://behalfid.com
# Used in email verification and reset links. Defaults to NEXT_PUBLIC_APP_URL if unset.
APP_BASE_URL=https://behalfid.com

# ── Transactional email (SMTP) ─────────────────────────────────────────────────
# iCloud+ custom domain: use smtp.mail.me.com:587 with STARTTLS (SMTP_SECURE=false).
# Generate an app-specific password at appleid.apple.com → Sign-In & Security → App-Specific Passwords.
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=support@behalfid.com
SMTP_PASS=
EMAIL_FROM=BehalfID <support@behalfid.com>

# Required in production. Generate a strong value; known placeholders are unsafe.
BEHALFID_ADMIN_PASSWORD=
BEHALFID_SETUP_TOKEN=
BEHALFID_PUBLIC_AGENT_CREATION=false
BEHALFID_LOG_METADATA=true

# Optional: pepper for webhook HMAC signing. When set, the stored secretHash alone
# cannot forge signatures — the pepper must also be known. Generate with: openssl rand -hex 32
BEHALFID_WEBHOOK_SIGNING_PEPPER=

# Optional: set to "true" to trust X-Forwarded-For for client IP extraction (e.g. behind
# your own load balancer). Leave unset on Vercel — x-real-ip is used by default.
TRUST_PROXY_XFF=

# ── Rate limiting (Redis) ─────────────────────────────────────────────────────
# Required in production for shared durable rate limiting across instances.
# Set both or neither. Get from https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Stripe billing ────────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# Webhook secret: create an endpoint in Stripe dashboard pointing to /api/billing/webhook
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the Pro plan monthly subscription (from Stripe dashboard → Products)
STRIPE_PRO_PRICE_ID=price_...

# ── Ollama (AI-assisted permission drafting) ──────────────────────────────────
# localhost only works when Next.js and Ollama run on the same machine.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=30000

# Optional: bearer token for the secure Ollama proxy (scripts/ollama-secure-proxy.js).
# Generate with: openssl rand -hex 32
# Set this on both the proxy machine (OLLAMA_PROXY_TOKEN) and in Vercel env vars.
OLLAMA_PROXY_TOKEN=
OLLAMA_PROXY_MAX_BODY_BYTES=1048576
OLLAMA_PROXY_TIMEOUT_MS=60000
OLLAMA_PROXY_PORT=8787
OLLAMA_PROXY_HOST=127.0.0.1

# ── GitHub / npm (package publishing & Homebrew tap) ─────────────────────────
NPM_TOKEN=
HOMEBREW_TAP_TOKEN=
HOMEBREW_GITHUB_API_TOKEN=

# ── Social posting (Buffer autoposter) ───────────────────────────────────────
BUFFER_ACCESS_TOKEN=
BUFFER_BSKY_CHANNEL_ID=
BUFFER_LINKEDIN_CHANNEL_ID=

# ── X / Twitter (direct replies and recent-posts context) ────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_USERNAME=
