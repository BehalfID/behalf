MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/behalfid
# Required in production. Generate a strong value; known placeholders are unsafe.
BEHALFID_ADMIN_PASSWORD=
BEHALFID_PUBLIC_AGENT_CREATION=false
BEHALFID_SETUP_TOKEN=
BEHALFID_LOG_METADATA=true
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional: pepper for webhook HMAC signing. When set, the stored secretHash alone
# cannot forge signatures — the pepper must also be known. Generate with: openssl rand -hex 32
BEHALFID_WEBHOOK_SIGNING_PEPPER=
# Optional: set to "true" to trust X-Forwarded-For for client IP extraction (e.g. behind
# your own load balancer). Leave unset on Vercel — x-real-ip is used by default.
TRUST_PROXY_XFF=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://behalfid.com

# Local AI-assisted permission drafting. localhost only works when the Next.js server and Ollama run on the same machine.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=30000

# Optional: bearer token for the secure Ollama proxy (scripts/ollama-secure-proxy.js).
# Generate with: openssl rand -hex 32
# Set this on both the proxy machine (OLLAMA_PROXY_TOKEN) and in Vercel env vars.
OLLAMA_PROXY_TOKEN=

# Stripe billing. Required in production because billing routes are deployed.
# Get keys from https://dashboard.stripe.com/apikeys
# Webhook secret: create an endpoint in Stripe dashboard pointing to /api/billing/webhook
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the Pro plan monthly subscription (from Stripe dashboard → Products)
STRIPE_PRO_PRICE_ID=price_...
