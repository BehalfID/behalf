MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/behalfid
# Required in production. Generate a strong value; known placeholders are unsafe.
BEHALFID_ADMIN_PASSWORD=
BEHALFID_PUBLIC_AGENT_CREATION=false
BEHALFID_SETUP_TOKEN=
BEHALFID_LOG_METADATA=true
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://behalfid.com

# Local AI-assisted permission drafting. localhost only works when the Next.js server and Ollama run on the same machine.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=30000

# Optional: bearer token for the secure Ollama proxy (scripts/ollama-secure-proxy.js).
# Generate with: openssl rand -hex 32
# Set this on both the proxy machine (OLLAMA_PROXY_TOKEN) and in Vercel env vars.
OLLAMA_PROXY_TOKEN=
