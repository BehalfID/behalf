{
  "name": "@behalfid/sdk",
  "version": "0.2.1",
  "description": "BehalfID SDK — runtime permission verification for AI agents. Define what agents may do, verify before execution, fail closed.",
  "keywords": [
    "ai-agent",
    "agent-permissions",
    "llm",
    "authorization",
    "tool-calling",
    "ai-safety",
    "agentic",
    "permission",
    "verification",
    "fail-closed",
    "audit-log",
    "langchain",
    "openai",
    "anthropic"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/openai": {
      "types": "./dist/adapters/openai/index.d.ts",
      "import": "./dist/adapters/openai/index.js"
    },
    "./adapters/anthropic": {
      "types": "./dist/adapters/anthropic/index.d.ts",
      "import": "./dist/adapters/anthropic/index.js"
    },
    "./adapters/langchain": {
      "types": "./dist/adapters/langchain/index.d.ts",
      "import": "./dist/adapters/langchain/index.js"
    },
    "./adapters/llamaindex": {
      "types": "./dist/adapters/llamaindex/index.d.ts",
      "import": "./dist/adapters/llamaindex/index.js"
    },
    "./adapters/stripe": {
      "types": "./dist/adapters/stripe/index.d.ts",
      "import": "./dist/adapters/stripe/index.js"
    },
    "./adapters/shared": {
      "types": "./dist/adapters/shared/index.d.ts",
      "import": "./dist/adapters/shared/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/behalfid/behalf.git",
    "directory": "packages/sdk"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
